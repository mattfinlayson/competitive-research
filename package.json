{
  "name": "competitive-research",
  "version": "0.1.0",
  "description": "Competitive research skills library for AI agents",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts && prettier --check src",
    "lint:fix": "eslint src --ext .ts --fix && prettier --write src",
    "build": "tsc",
    "cli": "tsx src/cli/naming-research.ts"
  },
  "keywords": [
    "spellbook",
    "skills",
    "competitive-analysis",
    "naming",
    "research"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
