#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Run lint first
echo "📝 Running linter..."
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ Linting failed. Please fix the issues above."
  exit 1
fi

# Run tests
echo "🧪 Running tests..."
npm run test:run
if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Please fix the issues above."
  exit 1
fi

# Run build
echo "🔨 Running build..."
npm run build
if [ $? -ne 0 ]; then
  echo "❌ Build failed. Please fix the issues above."
  exit 1
fi

echo "✅ All pre-commit checks passed!"
